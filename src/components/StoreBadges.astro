---
import type { StoreLinks } from '../data/products';

interface Props {
  links: StoreLinks;
  appName: string;
}

const { links, appName } = Astro.props;
---

<div class="store-row" aria-label={`Download links for ${appName}`}>
  {
    links.appStore && (
      <a class="store-button" href={links.appStore} target="_blank" rel="noopener">
        <span class="store-logo" aria-hidden="true">
          <svg viewBox="0 0 24 24" role="img" focusable="false">
            <path
              fill="currentColor"
              d="M16.6 1.7c.1 1-.3 2-.9 2.8-.7.8-1.7 1.4-2.8 1.3-.1-1 .4-2 1-2.8.7-.8 1.8-1.3 2.7-1.3zM20.3 17.1c-.5 1.2-.8 1.8-1.6 2.8-1 1.4-2.4 3.1-4.1 3.1-1.5 0-1.9-1-4-1s-2.5 1-4 1c-1.7 0-3-1.6-4-3-2.7-3.9-3-8.4-1.3-10.9 1.2-1.8 3-2.8 4.6-2.8 1.6 0 2.7 1 4 1 1.2 0 2.1-1 4-1 1.5 0 3 .8 4 2.1-3.5 1.9-2.9 6.8.4 8.7z"
            />
          </svg>
        </span>
        <span class="store-text"><small>Download on the</small><strong>App Store</strong></span>
      </a>
    )
  }
  {
    links.googlePlay && (
      <a class="store-button" href={links.googlePlay} target="_blank" rel="noopener">
        <span class="store-logo" aria-hidden="true">
          <svg viewBox="0 0 24 24" role="img" focusable="false">
            <path fill="#55d2c6" d="M3.6 2.6 14.7 12 3.6 21.4c-.3-.3-.5-.8-.5-1.3V3.9c0-.5.2-1 .5-1.3z" />
            <path fill="#ffd64d" d="m14.7 12-11.1-9.4c.5-.3 1.1-.3 1.7 0l12.9 7.3-3.5 2.1z" />
            <path fill="#ef5a37" d="m14.7 12 3.5 2.1-12.9 7.3c-.6.3-1.2.3-1.7 0L14.7 12z" />
            <path fill="#fff" d="m18.2 9.9 2 1.1c1 .6 1 1.9 0 2.5l-2 1.1-3.5-2.6 3.5-2.1z" />
          </svg>
        </span>
        <span class="store-text"><small>Get it on</small><strong>Google Play</strong></span>
      </a>
    )
  }
  {
    links.web && (
      <a class="store-button" href={links.web} target="_blank" rel="noopener">
        <span class="store-logo" aria-hidden="true">
          <svg viewBox="0 0 24 24" role="img" focusable="false">
            <circle cx="12" cy="12" r="9.2" fill="none" stroke="currentColor" stroke-width="1.6" />
            <ellipse cx="12" cy="12" rx="4.2" ry="9.2" fill="none" stroke="currentColor" stroke-width="1.6" />
            <path d="M2.8 12h18.4M4.2 7h15.6M4.2 17h15.6" fill="none" stroke="currentColor" stroke-width="1.6" />
          </svg>
        </span>
        <span class="store-text"><small>Play free in your</small><strong>Browser</strong></span>
      </a>
    )
  }
</div>
