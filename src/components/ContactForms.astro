---
import { formConfig } from '../data/site';
import { products } from '../data/products';

const productOptions = products.map((product) =>
  product.status === 'upcoming' ? `${product.name} (upcoming)` : product.name
);
---

<section id="contact" class="section">
  <div class="container contact-layout">
    <aside class="panel section-copy">
      <span class="eyebrow">Contact</span>
      <h2>Questions and bug reports land with me, not a ticket queue.</h2>
      <p>
        Every app on this site is built and supported by one person. Whether something broke,
        you have an idea, or you just want to say hi — I read everything and reply myself.
      </p>

      <ul class="contact-list">
        <li>
          <strong>👋 Say hello</strong>
          <span>Questions, ideas, press, or anything marching-arts related.</span>
        </li>
        <li>
          <strong>🛠️ Get help with an app</strong>
          <span>Bug reports, feature requests, and troubleshooting for WidgText and Marching Tycoon.</span>
        </li>
        <li>
          <strong>📣 SetFlow updates</strong>
          <span>Interested in the beta? Use the contact form and mention SetFlow.</span>
        </li>
      </ul>
    </aside>

    <div class="form-grid">
      <section class="panel form-card">
        <h3>Get in touch</h3>
        <p>Share your question or idea and I’ll respond as soon as I can.</p>

        <form data-form-type="contact">
          <div class="field">
            <label for="contact-name">Name</label>
            <input id="contact-name" name="name" type="text" autocomplete="name" required />
          </div>

          <div class="field">
            <label for="contact-email">Email</label>
            <input id="contact-email" name="email" type="email" autocomplete="email" required />
          </div>

          <div class="field field-wide">
            <label for="contact-subject">Subject</label>
            <input
              id="contact-subject"
              name="subject"
              type="text"
              placeholder="What would you like to talk about?"
              required
            />
          </div>

          <div class="field field-wide">
            <label for="contact-message">Message</label>
            <textarea
              id="contact-message"
              name="message"
              placeholder="A few details help me respond well. Writing about SetFlow? Say so and I’ll keep you posted."
              required
            ></textarea>
          </div>

          <input type="hidden" name="form_kind" value="contact" />

          <div class="form-actions">
            <button type="submit">Send message</button>
            <span class="form-note">A confirmation will appear here after you send.</span>
          </div>

          <p class="form-status" aria-live="polite"></p>
        </form>
      </section>

      <section class="panel form-card">
        <h3>App support</h3>
        <p>Tell me what happened and what you expected — I’ll dig in.</p>

        <form data-form-type="support">
          <div class="field">
            <label for="support-app">Which app?</label>
            <select id="support-app" name="app" required>
              <option value="">Select the app</option>
              {productOptions.map((name) => <option value={name}>{name}</option>)}
              <option value="Not sure">I’m not sure</option>
            </select>
          </div>

          <div class="field">
            <label for="support-type">Issue type</label>
            <select id="support-type" name="issue_type" required>
              <option value="">Select type</option>
              <option value="Bug report">Bug report</option>
              <option value="Feature request">Feature request</option>
              <option value="Need help">Need help</option>
            </select>
          </div>

          <div class="field field-wide">
            <label for="support-email">Email</label>
            <input id="support-email" name="email" type="email" autocomplete="email" required />
          </div>

          <div class="field field-wide">
            <label for="support-description">Description</label>
            <textarea
              id="support-description"
              name="description"
              placeholder="What happened, what you expected, and any steps to reproduce it."
              required
            ></textarea>
          </div>

          <input type="hidden" name="form_kind" value="support" />

          <div class="form-actions">
            <button type="submit">Submit request</button>
            <span class="form-note">Helpful details make for faster fixes.</span>
          </div>

          <p class="form-status" aria-live="polite"></p>
        </form>
      </section>
    </div>
  </div>
</section>

<script
  is:inline
  define:vars={{
    contactEndpoint: formConfig.contactEndpoint,
    supportEndpoint: formConfig.supportEndpoint
  }}
>
  const formEndpoints = {
    contact: contactEndpoint,
    support: supportEndpoint
  };

  function setStatus(form, message, statusClass) {
    const statusNode = form.querySelector('.form-status');
    if (!statusNode) return;
    statusNode.textContent = message;
    statusNode.className = `form-status ${statusClass}`.trim();
  }

  async function submitToEndpoint(endpoint, formData) {
    const response = await fetch(endpoint, {
      method: 'POST',
      headers: {
        Accept: 'application/json'
      },
      body: formData
    });

    if (!response.ok) {
      throw new Error('Submission failed');
    }
  }

  document.querySelectorAll('form[data-form-type]').forEach((form) => {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!form.reportValidity()) {
        return;
      }

      const submitButton = form.querySelector('button[type="submit"]');
      const type = form.dataset.formType;
      const endpoint = formEndpoints[type];
      const formData = new FormData(form);

      if (!submitButton || !endpoint) {
        setStatus(form, 'This form is not configured correctly.', 'error');
        return;
      }

      submitButton.disabled = true;
      submitButton.textContent = 'Sending...';
      setStatus(form, '', '');

      try {
        await submitToEndpoint(endpoint, formData);
        form.reset();
        setStatus(form, 'Message sent! I’ll follow up as soon as I can. 🎉', 'success');
      } catch (error) {
        setStatus(form, 'The message could not be sent. Please try again.', 'error');
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = type === 'contact' ? 'Send message' : 'Submit request';
      }
    });
  });
</script>
