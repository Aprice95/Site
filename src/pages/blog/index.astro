---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await Astro.glob('./*.md')).sort(
  (a, b) => new Date(b.frontmatter.publishDate).getTime() - new Date(a.frontmatter.publishDate).getTime()
);
---

<BaseLayout title="Blog | Aaron Michael Price" description="Product notes, release updates, support changes, and writing about the work.">
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Blog</span>
          <h1 class="page-title">Blog</h1>
        </div>
        <p>The blog is now a first-class part of the site: one post per file, clean URLs, and room for richer content over time.</p>
      </div>

      <div class="post-list">
        {
          posts.map((post) => (
            <a class="panel post-list-item" href={post.url}>
              <div>
                <p class="card-meta">{post.frontmatter.category} / {post.frontmatter.publishDate}</p>
                <h2>{post.frontmatter.title}</h2>
                <p>{post.frontmatter.excerpt}</p>
              </div>
              <span class="text-link">Read post</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
