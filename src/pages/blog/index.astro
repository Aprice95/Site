---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/paths';

const posts = Object.values(
  import.meta.glob('./*.md', { eager: true })
).sort((a, b) => new Date(b.frontmatter.publishDate).getTime() - new Date(a.frontmatter.publishDate).getTime());
---

<BaseLayout title="Blog | Aaron Price" description="Product notes, release updates, and writing about building indie apps.">
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Blog</span>
          <h1 class="page-title">The blog</h1>
        </div>
        <p>Product notes, release updates, and the decisions behind the apps — written as they happen.</p>
      </div>

      <div class="post-list">
        {
          posts.map((post) => (
            <a class="panel post-list-item" href={withBase(post.url ?? '/blog')}>
              <div>
                <p class="card-meta">{post.frontmatter.category} / {post.frontmatter.publishDate}</p>
                <h2>{post.frontmatter.title}</h2>
                <p>{post.frontmatter.excerpt}</p>
              </div>
              <span class="text-link">Read post</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
