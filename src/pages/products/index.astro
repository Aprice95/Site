---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StoreBadges from '../../components/StoreBadges.astro';
import { products } from '../../data/products';
import { withBase } from '../../lib/paths';
---

<BaseLayout
  title="Apps | Aaron Price"
  description="WidgText and Marching Tycoon are out now on the App Store and Google Play. SetFlow, a marching-arts rehearsal app, is up next."
>
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Apps</span>
          <h1 class="page-title">The apps</h1>
        </div>
        <p>
          Two shipped, one on the way — all built around the same idea: fewer apps, more care.
        </p>
      </div>

      <div class="products-grid">
        {
          products.map((product) => (
            <article class="panel product-card">
              <div class="product-card-head">
                <img src={withBase(product.icon)} alt="" width="512" height="512" loading="lazy" />
                <div>
                  <h3>{product.name}</h3>
                  <span class={`chip ${product.status === 'shipped' ? 'chip-live' : 'chip-soon'}`}>
                    {product.statusLabel}
                  </span>
                </div>
              </div>

              <p>{product.shortDescription}</p>

              {product.status === 'shipped' ? (
                <StoreBadges links={product.links} appName={product.name} />
              ) : (
                <div class="button-row">
                  <a class="button button-secondary" href={withBase('/products/setflow#notify')}>
                    Get notified at launch
                  </a>
                </div>
              )}

              <a class="text-link" href={withBase(`/products/${product.slug}`)}>
                More about {product.name} →
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
