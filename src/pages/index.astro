---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForms from '../components/ContactForms.astro';
import StoreBadges from '../components/StoreBadges.astro';
import { shippedProducts, products } from '../data/products';
import { withBase } from '../lib/paths';

const posts = Object.values(import.meta.glob('./blog/*.md', { eager: true }))
  .sort(
    (a, b) =>
      new Date(b.frontmatter.publishDate).getTime() - new Date(a.frontmatter.publishDate).getTime()
  )
  .slice(0, 3);

const setflow = products.find((p) => p.slug === 'setflow');
const widgtext = products.find((p) => p.slug === 'widgtext');
const marchingTycoon = products.find((p) => p.slug === 'marching-tycoon');
---

<BaseLayout
  title="Aaron Price | Indie Apps from Athens, Georgia"
  description="WidgText custom text widgets for iPhone, Marching Tycoon — a retro idle band game for iOS and Android — and SetFlow, a marching-arts rehearsal app in the works."
  ogImage="/images/apps/widgtext-shot-1.jpg"
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Aaron Price · Indie apps from Athens, Georgia</span>
        <h1>Apps that keep time.</h1>
        <p class="lead">
          A one-person studio rooted in the marching arts: a widget app for words worth seeing,
          an idle game about building a band, and a full drill-rehearsal app on the way.
        </p>
        <div class="button-row">
          <a class="button button-primary" href={withBase('/products')}>See the apps</a>
          <a class="button button-secondary" href={withBase('/blog')}>Read the blog</a>
        </div>
        <p class="hero-note">Live on the App Store and Google Play. 🎶</p>
      </div>

      <div class="icon-stack" aria-hidden="true">
        <div class="icon-card tilt-left">
          <img src={withBase(widgtext.icon)} alt="" width="512" height="512" loading="eager" />
          <span>WidgText</span>
          <span class="chip chip-live">Live</span>
        </div>
        <div class="icon-card front">
          <img src={withBase(marchingTycoon.icon)} alt="" width="512" height="512" loading="eager" />
          <span>Marching Tycoon</span>
          <span class="chip chip-live">Live</span>
        </div>
        <div class="icon-card tilt-right">
          <img src={withBase(setflow.icon)} alt="" width="512" height="512" loading="eager" />
          <span>SetFlow</span>
          <span class="chip chip-soon">Up next</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="apps">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Shipped</span>
          <h2>Out now, built with care.</h2>
        </div>
        <p>Two apps in the wild — one for your Home Screen, one for your inner drum major.</p>
      </div>

      <div class="app-showcase">
        <article class="app-feature">
          <div class="app-feature-body">
            <div class="app-feature-head">
              <img src={withBase(widgtext.icon)} alt="" width="512" height="512" loading="lazy" />
              <div>
                <h3>{widgtext.name}</h3>
                <p>{widgtext.tagline}</p>
              </div>
            </div>
            <p>{widgtext.shortDescription}</p>
            <ul class="feature-list">
              <li>50+ fonts, multi-color gradients, and six border styles</li>
              <li>Quote Mode rotates your own list every refresh</li>
              <li>Home Screen and Lock Screen, up to eight widget slots</li>
            </ul>
            <div class="app-feature-links">
              <StoreBadges links={widgtext.links} appName={widgtext.name} />
              <a class="text-link" href={withBase('/products/widgtext')}>More about WidgText →</a>
            </div>
          </div>
          <div class="app-shot">
            <img
              src={withBase(widgtext.screenshots[0].src)}
              alt={widgtext.screenshots[0].alt}
              width="640"
              height="1390"
              loading="lazy"
            />
          </div>
        </article>

        <article class="app-feature dark">
          <div class="app-feature-body">
            <div class="app-feature-head">
              <img src={withBase(marchingTycoon.icon)} alt="" width="512" height="512" loading="lazy" />
              <div>
                <h3>{marchingTycoon.name}</h3>
                <p>{marchingTycoon.tagline}</p>
              </div>
            </div>
            <p>{marchingTycoon.shortDescription}</p>
            <ul class="feature-list">
              <li>Tap the metronome — good timing boosts your Reps</li>
              <li>Offline progress keeps rehearsal moving while you're away</li>
              <li>Fifteen competition tiers, from local shows to galactic finals</li>
            </ul>
            <div class="app-feature-links">
              <StoreBadges links={marchingTycoon.links} appName={marchingTycoon.name} />
              <a class="text-link" href={withBase('/products/marching-tycoon')}
                >More about Marching Tycoon →</a
              >
            </div>
          </div>
          <div class="app-shot">
            <img
              src={withBase(marchingTycoon.screenshots[0].src)}
              alt={marchingTycoon.screenshots[0].alt}
              width="640"
              height="1390"
              loading="lazy"
            />
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="setflow-band">
        <div class="setflow-inner">
          <div class="setflow-copy">
            <span class="eyebrow">Up next · SetFlow</span>
            <h2>Marching show rehearsal, synced from drill to performance.</h2>
            <p>{setflow.shortDescription}</p>
            <div class="button-row">
              <a class="button button-primary" href={withBase('/products/setflow')}>See what's coming</a>
              <a class="button button-secondary" href={withBase('/products/setflow#notify')}>Get notified</a>
            </div>
          </div>
          <div class="setflow-points">
            <div>
              <strong>Import the packet</strong>
              <span>Drill, score, coordinates, and show audio in one place.</span>
            </div>
            <div>
              <strong>Rehearse in sync</strong>
              <span>Learn and Flow modes with a metronome locked to show audio.</span>
            </div>
            <div>
              <strong>Check dots in AR</strong>
              <span>See the formation on the real field, at full scale.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-tint">
    <div class="container about-grid">
      <div class="about-copy">
        <span class="eyebrow">About</span>
        <h2>Hi, I'm Aaron. 👋</h2>
        <p>
          I'm an independent developer in Athens, Georgia. I grew up in the marching arts, and
          most of what I build starts there — a rehearsal tool for the field and a game about
          band life, alongside a widget app for everyone else.
        </p>
        <p>
          Everything on this site is designed, built, and supported by one person. That means
          fewer apps, more care, and a direct line to me when something needs fixing.
        </p>
      </div>
      <div class="about-facts">
        <div class="about-fact">
          <strong>{shippedProducts.length}</strong>
          <span>apps shipped and counting</span>
        </div>
        <div class="about-fact">
          <strong>5.0★</strong>
          <span>Marching Tycoon's App Store rating</span>
        </div>
        <div class="about-fact">
          <strong>1</strong>
          <span>person behind the code, design, and support</span>
        </div>
        <div class="about-fact">
          <strong>ATH</strong>
          <span>made in Athens, Georgia 🍑</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Blog</span>
          <h2>Latest writing</h2>
        </div>
        <p>Product notes, release updates, and the decisions behind the work.</p>
      </div>

      <div class="post-grid">
        {
          posts.map((post) => (
            <a class="panel post-card" href={withBase(post.url ?? '/blog')}>
              <p class="card-meta">
                {post.frontmatter.category} · {post.frontmatter.publishDate}
              </p>
              <h3>{post.frontmatter.title}</h3>
              <p>{post.frontmatter.excerpt}</p>
              <span class="text-link">Read post →</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <ContactForms />
</BaseLayout>
